{
  "name": "mai-reminder",
  "version": "0.4.2",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "start": "concurrently -k -n VITE,ELECTRON -c blue,yellow \"vite\" \"wait-on tcp:3000 && npm run rebuild && npm run build:electron && NODE_ENV=development electron dist-electron/electron/main.js\"",
    "dev": "vite",
    "build": "npm run typecheck && vite build && npm run build:electron",
    "build:electron": "node -e \"['dist-electron', 'release'].forEach(d => require('fs').rmSync(d, {recursive:true, force:true}))\" && tsc --project tsconfig.electron.json && node -e \"require('fs').writeFileSync('dist-electron/package.json', JSON.stringify({type: 'commonjs'}))\"",
    "dist": "npm run build && electron-builder --config electron-builder.yml",
    "ensure-sqlite-proguard": "node scripts/ensure-sqlite-proguard.js",
    "rebuild": "node -e \"try { require('fs').rmSync('node_modules/better-sqlite3/build', {recursive:true, force:true}) } catch(e) {}\" && electron-builder install-app-deps",
    "rebuild:system": "npm rebuild better-sqlite3 --runtime=node",
    "postinstall": "patch-package && npm run ensure-sqlite-proguard && npm run rebuild",
    "test": "npm run rebuild:system && vitest run",
    "test:watch": "npm run rebuild:system && vitest",
    "test:e2e": "npm run rebuild && npm run build:electron && playwright test",
    "test:e2e:electron": "npm run rebuild && npm run build:electron && playwright test e2e/electron.suite.spec.ts",
    "test:perf": "vitest run tests/performance",
    "test:e2e:perf": "npm run rebuild && playwright test e2e/performance.spec.ts",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "build:web": "vite build",
    "build:mobile": "npm run build:web && npx cap sync",
    "cap:sync": "npx cap sync",
    "test:android:e2e": "cd android && ./gradlew connectedAndroidTest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@capacitor-community/sqlite": "8.0.0",
    "@capacitor/android": "8.1.0",
    "@capacitor/app": "8.0.1",
    "@capacitor/core": "8.1.0",
    "@capacitor/ios": "8.1.0",
    "@capacitor/local-notifications": "8.0.1",
    "@capacitor/preferences": "8.0.1",
    "@capacitor/status-bar": "8.0.1",
    "@capgo/capacitor-speech-recognition": "8.0.10",
    "@ionic/vue": "8.0.0",
    "@ionic/vue-router": "8.0.0",
    "@supabase/supabase-js": "2.98.0",
    "better-sqlite3": "12.6.2",
    "chrono-node": "2.9.0",
    "libsodium-wrappers": "0.8.2",
    "pinia": "2.1.7",
    "rrule": "2.8.1",
    "v-calendar": "3.1.2",
    "vosk-koffi": "1.1.1",
    "vue": "3.4.0",
    "vue-i18n": "9.14.5",
    "vue-router": "4.2.5"
  },
  "devDependencies": {
    "@capacitor/cli": "8.1.0",
    "@playwright/test": "1.58.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/libsodium-wrappers": "0.7.14",
    "@typescript-eslint/eslint-plugin": "8.56.0",
    "@typescript-eslint/parser": "8.56.0",
    "@vitejs/plugin-vue": "5.0.0",
    "@vitest/coverage-v8": "1.6.1",
    "@vue/test-utils": "2.4.4",
    "concurrently": "9.2.1",
    "electron": "40.6.0",
    "electron-builder": "26.8.1",
    "eslint": "8.57.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "9.20.0",
    "happy-dom": "13.3.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "patch-package": "8.0.1",
    "prettier": "3.8.1",
    "typescript": "5.3.0",
    "vite": "5.0.0",
    "vitest": "1.2.0",
    "vue-tsc": "1.8.0",
    "wait-on": "9.0.4"
  }
}
